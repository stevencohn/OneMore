<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">

  <!--
    ArchFlag mirrors the same casing fix in OneMoreSetup/Product.wxs:
    sys.BUILDARCH is lowercase (arm64), but the MSI filename uses ARM64.

    MsiArchFlag controls which MSI the bundle embeds:
    - Standard ARM64 build: ARM64 bundle wraps ARM64 MSI (MixedArch=false).
    - ARM64x64 mixed build: ARM64 bundle wraps x64 MSI (MixedArch=true).
      ARM64EC Office (Office on ARM64 Windows) requires x64 OneMore because
      dllhost.exe (the COM surrogate) runs as x64 in that configuration.
  -->
  <?define ArchFlag = $(sys.BUILDARCH) ?>
  <?define MsiArchFlag = $(sys.BUILDARCH) ?>
  <?if $(sys.BUILDARCH) = arm64 ?>
    <?undef ArchFlag ?>
    <?define ArchFlag = ARM64 ?>
    <?undef MsiArchFlag ?>
    <?if $(var.MixedArch) = true ?>
      <?define MsiArchFlag = x64 ?>
    <?else ?>
      <?define MsiArchFlag = ARM64 ?>
    <?endif ?>
  <?endif ?>

  <Bundle Name="OneMore Add-in"
          Version="$(var.ProductVersion)"
          Manufacturer="River"
          UpgradeCode="{BC32678A-CE28-476B-9A12-181EF4523358}">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        Theme="rtfLicense"
        LicenseFile="..\OneMoreSetup\Resources\license.rtf"
        LogoFile="..\OneMore\Properties\Images\Logo.ico" />
    </BootstrapperApplication>

    <Chain>
      <MsiPackage
        SourceFile="..\OneMoreSetup\bin\$(var.MsiArchFlag)\$(var.Configuration)\OneMore_$(var.ProductVersion)_Setup$(var.MsiArchFlag).msi" />
    </Chain>

  </Bundle>
</Wix>
