{
  "name": "Python",
  "rules": [
    {
      // [2] (""" comment """)
      // single line multi-line comment
      "pattern": "^((?:\\s*)\"{3}[^\\r\\n]*?\"{3}(?:\\s*))$",
      "captures": [
        "Comment"
      ]
    },
    {
      // [3] (""" comment)
      // start of a multi-line comment
      "pattern": "^((?:\\s*)\"{3}[^\\r\\n]*)$",
      "scope": "Comment",
      "captures": [
        "Comment"
      ]
    },
    {
      // [4] (comment """)
      // end of a multi-line comment
      "pattern": "([^\\r\\n\"]*\"{3}(?:\\s*))",
      "scope": "",
      "captures": [
        "Comment"
      ]
    },
    {
      // [5] (# comment)
      "pattern": "(#[^\\r\\n]*)[]\\r\\n]?$",
      "captures": [
        "Comment"
      ]
    },
    {
      // prefixed triple-quoted string (single-line): f"""...""", r"""...""", b"""...""", rb"""..."""
      "pattern": "((?:[rRbBfFuU]{1,2})\"{3}[^\\r\\n]*?\"{3})",
      "captures": [
        "String"
      ]
    },
    {
      // prefixed triple-quoted string (single-line, single-quoted): f'''...''', r'''...''', etc.
      "pattern": "((?:[rRbBfFuU]{1,2})'{3}[^\\r\\n]*?'{3})",
      "captures": [
        "String"
      ]
    },
    {
      // prefixed string (double-quoted): f"...", r"...", b"...", rb"...", fr"..."
      "pattern": "((?:[rRbBfFuU]{1,2})\"[^\\r\\n\"]*?\")",
      "captures": [
        "String"
      ]
    },
    {
      // prefixed string (single-quoted): f'...', r'...', b'...', etc.
      "pattern": "((?:[rRbBfFuU]{1,2})'[^\\r\\n']*?')",
      "captures": [
        "String"
      ]
    },
    {
      // [6] ('string')
      "pattern": "('[^\\r\\n\\']*\\')",
      "captures": [
        "String"
      ]
    },
    {
      // [7] ("string")
      "pattern": "(\"[^\\r\\n\"]*\")",
      //"pattern": "\"(?:([^{}\"]+)|(\\{[^{}\"]+\\})+)\"", ;string,number
      "captures": [
        "String"
      ]
    },
    {
      // decorator at line start: @decorator, @module.func, @obj.method
      // line-anchored to avoid matching the @ matrix-multiplication operator (Python 3.5+)
      "pattern": "^\\s*(@[a-zA-Z_][a-zA-Z0-9_\\.]*)",
      "captures": [
        "Macro"
      ]
    },
    {
      // [8] (keyword)
      "pattern": "\\b(and|as|assert|async|await|break|case|class|continue|def|del|elif|else|except|exec|False|finally|for|from|global|if|import|in|is|lambda|match|None|nonlocal|not|or|pass|print|raise|return|True|try|while|with|yield)\\b",
      "captures": [
        "Keyword"
      ]
    },
    {
      // [9] (1234)
      "pattern": "\\b([0-9]{1,})\\b",
      "captures": [
        "Number"
      ]
    }
  ]
}
