      <Component Id="SatelliteJaJpT" Directory="CultureJaJp">
        <File Source="..\OneMore\bin\$(var.Configuration)\ja-JP\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- nl-NL -->
      <Component Id="SatelliteNlNl" Directory="CultureNlNl">
        <File Source="..\OneMore\bin\$(var.Configuration)\nl-NL\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatelliteNlNlT" Directory="CultureNlNl">
        <File Source="..\OneMore\bin\$(var.Configuration)\nl-NL\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- pl-PL -->
      <Component Id="SatellitePlPl" Directory="CulturePlPl">
        <File Source="..\OneMore\bin\$(var.Configuration)\pl-PL\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatellitePlPlT" Directory="CulturePlPl">
        <File Source="..\OneMore\bin\$(var.Configuration)\pl-PL\OneMoreTray.resources.dll" KeyPath="yes" />
