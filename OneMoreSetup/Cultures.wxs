<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Satellite assemblies (localized resources) installed to INSTALLDIR\[culture]\ -->
  <Fragment>
    <ComponentGroup Id="SatelliteAssemblies" Directory="INSTALLDIR">
      <!-- ar-SA -->
      <Component Id="SatelliteArSaAddIn" Directory="CultureArSA">
        <File Source="..\OneMore\bin\$(var.Configuration)\ar-SA\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatelliteArSaTray" Directory="CultureArSA">
        <File Source="..\OneMore\bin\$(var.Configuration)\ar-SA\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- de-DE -->
      <Component Id="SatelliteDeDeDe" Directory="CultureDeDe">
        <File Source="..\OneMore\bin\$(var.Configuration)\de-DE\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatelliteDeDeT" Directory="CultureDeDe">
        <File Source="..\OneMore\bin\$(var.Configuration)\de-DE\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- es-ES -->
      <Component Id="SatelliteEsEs" Directory="CultureEsEs">
        <File Source="..\OneMore\bin\$(var.Configuration)\es-ES\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatelliteEsEsT" Directory="CultureEsEs">
        <File Source="..\OneMore\bin\$(var.Configuration)\es-ES\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

