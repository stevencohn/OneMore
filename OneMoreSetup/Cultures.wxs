      </Component>
      <Component Id="SatelliteFrFrT" Directory="CultureFrFr">
        <File Source="..\OneMore\bin\$(var.Configuration)\fr-FR\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- he-IL -->
      <Component Id="SatelliteHeIl" Directory="CultureHeIl">
        <File Source="..\OneMore\bin\$(var.Configuration)\he-IL\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>
      <Component Id="SatelliteHeIlT" Directory="CultureHeIl">
        <File Source="..\OneMore\bin\$(var.Configuration)\he-IL\OneMoreTray.resources.dll" KeyPath="yes" />
      </Component>

      <!-- it-IT -->
      <Component Id="SatelliteItIt" Directory="CultureItIt">
        <File Source="..\OneMore\bin\$(var.Configuration)\it-IT\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
      </Component>

      <!-- ja-JP -->
      <Component Id="SatelliteJaJp" Directory="CultureJaJp">
        <File Source="..\OneMore\bin\$(var.Configuration)\ja-JP\River.OneMoreAddIn.resources.dll" KeyPath="yes" />
